# -------------------------------------------------------------
# Guira Backend API - Entorno de Desarrollo (Development)
# Copy this file to .env.local and fill in your project values.
# -------------------------------------------------------------

# Puerto del servidor NestJS
PORT=3001

# Prefijo global de la API (ej: "api/v1" o "api")
PATH_SUBDOMAIN=api

# Orígenes permitidos para CORS (separados por coma)
URL_FRONTEND=http://localhost:3000,http://localhost:5173

# -------------------------------------------------------------
# SUPABASE BAAS (Base de Datos + Auth)
# -------------------------------------------------------------
# URL raíz del proyecto Supabase
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon key (solo para validación JWT en el guard de auth)
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# IMPORTANTE: Usar SERVICE ROLE KEY en backend, nunca el ANON KEY para queries.
# El Service Role permite saltar las reglas de RLS en operaciones CRON/Admin.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# -------------------------------------------------------------
# BRIDGE API (Procesamiento de pagos y creación de cuentas US)
# -------------------------------------------------------------
# Base URL (Usar sandbox para desarrollo, production para prod)
BRIDGE_API_URL=https://api.sandbox.bridge.xyz/v0

# API Key generada desde el dashboard de desarrollador de Bridge
BRIDGE_API_KEY=sk_test_your-bridge-api-key-here

# ID y Public Key para la verificación asimétrica (RSA/SHA256) de Webhooks de Bridge
BRIDGE_WEBHOOK_ID=wep_your-webhook-id-here
BRIDGE_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
BRIDGE_WEBHOOK_URL=https://your-domain.com/webhooks/bridge

# -------------------------------------------------------------
# ZEPTOMAIL (Envío de correos transaccionales)
# -------------------------------------------------------------
# Send Mail Token del dashboard de ZeptoMail (Mail Agent > API).
# Puede copiarse con o sin el prefijo "Zoho-enczapikey " — el cliente lo normaliza.
ZEPTOMAIL_TOKEN=Zoho-enczapikey wSsVR60...

# Endpoint de la API (normalmente no hace falta cambiarlo)
ZEPTOMAIL_API_URL=https://api.zeptomail.com/v1.1/email

# Dirección "from" verificada en ZeptoMail (debe pertenecer a un dominio verificado)
EMAIL_FROM_ADDRESS=noreply@your-domain.com

# Nombre visible del remitente
EMAIL_FROM_NAME=Guira
